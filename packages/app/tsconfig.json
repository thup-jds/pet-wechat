{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "removeComments": true,
    "preserveConstEnums": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "outDir": "lib",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": ".",
    "jsx": "react-jsx",
    "allowJs": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "node_modules/@tarojs/components/types",
      "node_modules/@types"
    ],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src",
    "config",
    "types"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
